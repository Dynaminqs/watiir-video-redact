# Copie en .env (gitignored) et remplit les valeurs.
# Cf. docs/deploy-scaleway-l4.md pour la procédure prod.

# Supabase staging WATIIR (project tdsdlptxsvlhscjoyuyc) ou prod
SUPABASE_URL=https://tdsdlptxsvlhscjoyuyc.supabase.co

# Clé service_role : Supabase Dashboard → Settings → API → service_role key
# NE JAMAIS COMMITER cette valeur.
SUPABASE_SERVICE_ROLE_KEY=

# Polling : 30s d'inactivité entre 2 RPC claim si la file est vide
POLL_INTERVAL_IDLE_S=30

# Vidéos > 10 min refusées (notify-video-redacted status=failed_redaction)
MAX_VIDEO_DURATION_S=600

# Timeout HTTP pour notify-video-redacted
REQUEST_TIMEOUT_S=30.0

# Chemins modèles (sinon défaut /app/models en Docker, ./models en dev local)
# MODELS_DIR=/app/models
# FACE_MODEL_PATH=/app/models/model.pt
# PLATE_MODEL_PATH=/app/models/best.pt
